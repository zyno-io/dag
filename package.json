{
    "name": "@zyno-io/dag-root",
    "version": "0.5.3",
    "private": true,
    "license": "MIT",
    "author": "Zyno Consulting <support@zyno.io>",
    "workspaces": [
        "packages/shared",
        "packages/server",
        "packages/cli",
        "packages/ui"
    ],
    "scripts": {
        "build": "yarn build:server && yarn build:cli && yarn build:ui",
        "build:server": "yarn workspace @zyno-io/dag-shared build && yarn workspace @zyno-io/dag build",
        "build:cli": "yarn workspace @zyno-io/dag-cli build",
        "build:ui": "yarn openapi && yarn workspace @zyno-io/dag-ui gen && yarn workspace @zyno-io/dag-ui build",
        "clean": "yarn workspaces foreach -A run clean",
        "dev:server": "yarn workspace @zyno-io/dag dev",
        "dev:ui": "yarn workspace @zyno-io/dag-ui dev",
        "openapi": "yarn workspace @zyno-io/dag openapi",
        "gen": "yarn build:server && yarn build:ui",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "sync-version": "bash scripts/sync-version.sh",
        "lint": "oxlint --fix --fix-suggestions --fix-dangerously",
        "format": "oxfmt --write ."
    },
    "devDependencies": {
        "lefthook": "^2.1.2",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.50.0",
        "vitepress": "^1.6.4"
    },
    "resolutions": {
        "@zyno-io/dag-ui/typescript": "6.0.3"
    },
    "packageManager": "yarn@4.17.1"
}
