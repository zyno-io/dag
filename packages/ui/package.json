{
    "name": "@zyno-io/dag-ui",
    "version": "0.5.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "rimraf node_modules/.vite && vite",
        "build": "run-p typecheck build-only",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
        "build-only": "vite build",
        "gen": "generate-openapi-client",
        "format": "npx oxlint --fix --fix-suggestions --fix-dangerously && oxfmt",
        "test:e2e": "playwright test",
        "test:e2e:update": "rimraf screenshots && playwright test"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@types/lodash": "^4.17.24",
        "@zyno-io/openapi-client-codegen": "^2.8.0",
        "@zyno-io/vue-foundation": "^4.33.5",
        "date-fns": "^4.1.0",
        "lodash": "^4.18.1",
        "pinia": "^3.0.4",
        "vue": "^3.5.34",
        "vue-router": "^5.0.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@tailwindcss/postcss": "^4.3.0",
        "@tsconfig/node22": "^22.0.5",
        "@types/node": "^25.6.2",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/tsconfig": "^0.9.1",
        "npm-run-all": "^4.1.5",
        "oxlint": "^1.73.0",
        "postcss": "^8.5.14",
        "rimraf": "^6.1.3",
        "sass": "^1.99.0",
        "tailwindcss": "~4",
        "typescript": "7.0.2",
        "vite": "^8.0.11",
        "vite-plugin-oxlint": "^2.1.1",
        "vue-tsc": "^3.2.8"
    }
}
