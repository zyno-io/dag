{
    "name": "@zyno-io/dag",
    "version": "0.4.0",
    "private": true,
    "main": "./dist/bootstrap.js",
    "scripts": {
        "clean": "tsf-dev clean",
        "build": "tsf-dev build",
        "openapi": "node dist/bootstrap.js openapi:generate",
        "dev": "PORT=${PORT:-3000} tsf-dev run -- server:start",
        "migrate": "tsf-dev migrate --migrations-dir dist/migrations",
        "migrate:create": "tsf-dev migrate:create",
        "migrate:reset": "tsf-dev migrate:reset",
        "test": "tsf-dev test",
        "test:debug": "tsf-dev test --debug",
        "postinstall": "tsf-install"
    },
    "dependencies": {
        "@kubernetes/client-node": "^1.4.0",
        "@zyno-io/dag-shared": "workspace:*",
        "@zyno-io/ts-server-foundation": "26.712.36",
        "js-yaml": "^4.1.1",
        "simple-git": "^3.32.3",
        "tar": "^7.5.9"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "ttsc": "0.18.3",
        "typescript": "7.0.2"
    },
    "packageManager": "yarn@4.17.1"
}
